#include "FreeRTOS.h"
#include "task.h"
#include "queue.h"
#include <stdint.h>
#include "timers.h"

/* RCC */
#define RCC_AHB1ENR (*(volatile uint32_t*)0x40023830)

/* GPIOD */
#define GPIOD_MODER (*(volatile uint32_t*)0x40020C00)
#define GPIOD_ODR   (*(volatile uint32_t*)0x40020C14)

void GPIO_Init(void)
{
    // Enable GPIOD clock
    RCC_AHB1ENR |= (1 << 3);

    // Set PD12 and PD13 as output
    GPIOD_MODER |= (1 << 24); // PD12
    GPIOD_MODER |= (1 << 26); // PD13
}

void TimerCallback(TimerHandle_t xTimer)
{
    GPIOD_ODR ^= (1 << 12); // Toggle LED
}
int main(void)
{
    GPIO_Init();

    myTimer = xTimerCreate("LED Timer",
                           pdMS_TO_TICKS(500),
                           pdTRUE,
                           NULL,
                           TimerCallback);

    if(myTimer == NULL)
    {
        while(1);
    }

    xTimerStart(myTimer, 0);

    vTaskStartScheduler();

    while(1);
}
