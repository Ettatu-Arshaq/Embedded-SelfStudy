#include "FreeRTOS.h"
#include "task.h"
#include "queue.h"
#include <stdint.h>
#include "timers.h"
#include <stdio.h>

TimerHandle_t myTimer;

#define RCC_AHB1ENR (*(volatile uint32_t*)0x40023830)
#define GPIOD_MODER (*(volatile uint32_t*)0x40020C00)
#define GPIOD_ODR   (*(volatile uint32_t*)0x40020C14)

#define RCC_APB1ENR (*(volatile uint32_t*)0x40023840)

/* GPIOA */
#define GPIOA_MODER (*(volatile uint32_t*)0x40020000)
#define GPIOA_AFRL  (*(volatile uint32_t*)0x40020020)

/* USART2 */
#define USART2_SR   (*(volatile uint32_t*)0x40004400)
#define USART2_DR   (*(volatile uint32_t*)0x40004404)
#define USART2_BRR  (*(volatile uint32_t*)0x40004408)
#define USART2_CR1  (*(volatile uint32_t*)0x4000440C)

SemaphoreHandle_t uartMutex;

void UART2_Init(void)
{
    // Enable clocks
    RCC_AHB1ENR |= (1 << 0); // GPIOA
    RCC_APB1ENR |= (1 << 17); // USART2

    // Clear first
    GPIOA_MODER &= ~(3 << 4);
    GPIOA_MODER |=  (2 << 4);

    // Clear AFRL
    GPIOA_AFRL &= ~(0xF << 8);
    GPIOA_AFRL |=  (7 << 8);

    // Baudrate (assuming 16MHz → 9600)
    USART2_BRR = 0x008B; // for 16 MHz → 115200

    // Enable TX + USART
    USART2_CR1 |= (1 << 3);
    USART2_CR1 |= (1 << 13);
}

void GPIO_Init(void)
{
    RCC_AHB1ENR |= (1 << 3); // Enable GPIOD

    GPIOD_MODER &= ~(3 << 24); // clear
    GPIOD_MODER |=  (1 << 24); // output
}

void TimerCallback(TimerHandle_t xTimer)
{
    GPIOD_ODR ^= (1 << 12);
}
void UART_SendChar(char c)
{
    while(!(USART2_SR & (1 << 7))); // TXE
    USART2_DR = c;
}

void UART_Print(char *str)
{
    while(*str)
    {
        UART_SendChar(*str++);
    }
}

int main(void)
{
    GPIO_Init();
    UART_Init();   // Make sure you have this

    uint32_t freeHeap = xPortGetFreeHeapSize();

    char buffer[50];
    sprintf(buffer, "Free Heap: %lu\r\n", freeHeap);
    UART_Print(buffer);

    vTaskStartScheduler();

    while(1);
}
