#include "FreeRTOS.h"
#include "task.h"
#include "queue.h"
#include <stdint.h>
#include "timers.h"

/* RCC */
#define RCC_AHB1ENR (*(volatile uint32_t*)0x40023830)
#define RCC_APB1ENR (*(volatile uint32_t*)0x40023840)

/* GPIOA */
#define GPIOA_MODER (*(volatile uint32_t*)0x40020000)
#define GPIOA_AFRL  (*(volatile uint32_t*)0x40020020)

/* USART2 */
#define USART2_SR   (*(volatile uint32_t*)0x40004400)
#define USART2_DR   (*(volatile uint32_t*)0x40004404)
#define USART2_BRR  (*(volatile uint32_t*)0x40004408)
#define USART2_CR1  (*(volatile uint32_t*)0x4000440C)

#define RCC_APB2ENR (*(volatile uint32_t*)0x40023844)
#define SYSCFG_EXTICR1 (*(volatile uint32_t*)0x40013808)
#define EXTI_IMR  (*(volatile uint32_t*)0x40013C00)
#define EXTI_FTSR (*(volatile uint32_t*)0x40013C0C)
#define EXTI_PR   (*(volatile uint32_t*)0x40013C14)
#define NVIC_ISER0 (*(volatile uint32_t*)0xE000E100)

QueueHandle_t uartRxQueue;
TimerHandle_t myTimer;
/* UART INIT */
void UART2_Init(void)
{
    RCC_AHB1ENR |= (1 << 0);
    RCC_APB1ENR |= (1 << 17);

    GPIOA_MODER &= ~(3 << 4);
    GPIOA_MODER |=  (2 << 4);

    GPIOA_AFRL &= ~(0xF << 8);
    GPIOA_AFRL |=  (7 << 8);

    USART2_BRR = 0x008B; // 115200 @16MHz

    USART2_CR1 |= (1 << 3);
    USART2_CR1 |= (1 << 13);
}

/* UART SEND */
void UART_SendChar(char c)
{
    while(!(USART2_SR & (1 << 7)));
    USART2_DR = c;
}

/* SEND NUMBER AS ASCII */
void UART_SendNumber(uint32_t num)
{
    char buffer[10];
    int i = 0;

    if(num == 0)
    {
        UART_SendChar('0');
        return;
    }

    while(num > 0)
    {
        buffer[i++] = (num % 10) + '0';
        num /= 10;
    }

    for(int j = i - 1; j >= 0; j--)
    {
        UART_SendChar(buffer[j]);
    }
}

void UART_Task(void *params)
{
    uint8_t data;

    while(1)
    {
        if(xQueueReceive(uartRxQueue, &data, portMAX_DELAY))
        {
            UART_SendChar(data); // echo back
        }
    }
}

void EXTI0_Init(void)
{
    RCC_AHB1ENR |= (1 << 0); // GPIOA clock
    RCC_APB2ENR |= (1 << 14); // SYSCFG clock

    GPIOA_MODER &= ~(3 << 0); // PA0 input

    SYSCFG_EXTICR1 &= ~(0xF << 0); // EXTI0 → PA0

    EXTI_IMR |= (1 << 0);  // Unmask
    EXTI_FTSR |= (1 << 0); // Falling edge trigger

    NVIC_ISER0 |= (1 << 6); // Enable EXTI0 IRQ
}

void EXTI0_IRQHandler(void)
{
    BaseType_t xHigherPriorityTaskWoken = pdFALSE;

    uint8_t receivedByte = 'X'; // simulate received data

    xQueueSendFromISR(uartRxQueue, &receivedByte, &xHigherPriorityTaskWoken);
    EXTI_PR |= (1 << 0);
    portYIELD_FROM_ISR(xHigherPriorityTaskWoken);

    // Clear interrupt flag (important)
}
/* MAIN */

void TimerCallback(TimerHandle_t xTimer)
{
    GPIOD_ODR ^= (1 << 12); // Toggle LED
}
int main(void)
{
    GPIO_Init();

    myTimer = xTimerCreate("LED Timer",
                           pdMS_TO_TICKS(500),
                           pdTRUE,
                           NULL,
                           TimerCallback);

    if(myTimer == NULL)
    {
        while(1);
    }

    xTimerStart(myTimer, 0);

    vTaskStartScheduler();

    while(1);
}
